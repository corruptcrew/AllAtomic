{
    "name": "AllAtomic Userbot",
    "description": "A turbocharged Telegram userbot with purple anime theme",
    "repository": "https://github.com/corruptcrew/AllAtomic",
    "logo": "https://i.imgur.com/2Qz9W1K.gif",
    "keywords": ["telegram", "userbot", "pyrogram", "allatomic"],
    "env": {
        "API_ID": {
            "description": "Get this from https://my.telegram.org",
            "required": true
        },
        "API_HASH": {
            "description": "Get this from https://my.telegram.org",
            "required": true
        },
        "BOT_TOKEN": {
            "description": "Bot token from @BotFather",
            "required": true
        },
        "DATABASE_URL": {
            "description": "MongoDB connection string",
            "required": true
        },
        "LOGGER_ID": {
            "description": "Logger group/channel ID (include negative sign for channels)",
            "required": true
        },
        "OWNER_ID": {
            "description": "Your Telegram user ID",
            "required": true
        },
        "HANDLERS": {
            "description": "Command handlers (default: . ! ?)",
            "value": ". ! ?",
            "required": false
        }
    },
    "formation": {
        "worker": {
            "quantity": 1,
            "size": "basic"
        }
    },
    "stack": "container"
}
