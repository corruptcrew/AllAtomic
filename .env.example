# AllAtomic Userbot - Environment Variables
# Copy this file to .env and fill in your values

# Telegram API Credentials (Get from https://my.telegram.org)
API_ID=
API_HASH=

# Bot Token (Get from @BotFather)
BOT_TOKEN=

# MongoDB Database URL
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/allatomic?retryWrites=true&w=majority

# Logger Group/Channel ID (Include negative sign for channels)
LOGGER_ID=

# Your Telegram User ID
OWNER_ID=

# Command Handlers (optional, default: . ! ?)
HANDLERS=. ! ?

# Heroku Configuration (optional)
# HEROKU_APPNAME=
# HEROKU_APIKEY=

# Plugin Repository (optional)
# PLUGINS_REPO=corruptcrew/AllAtomic
