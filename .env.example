# AllAtomic - Environment Variables
Dev: @GhostMarshal | Channel: @ComputeCode
(૨๑•̀ㅁ•́ฅा) Purple Anime Theme (#9A8CFF)

# Copy this file to .env and fill in your values

# =============================
# Telegram API Credentials
# =============================
API_ID=your_api_id_here
API_HASH=your_api_hash_here
STRING_SESSION=your_string_session_here
BOT_TOKEN=your_bot_token_here

# =============================
# MongoDB Configuration
# =============================
MONGO_URL=mongodb://localhost:27017
DB_NAME=AllAtomic

# =============================
# Owner & Admin Settings
# =============================
OWNER_ID=your_user_id_here
SUDO_USERS=your_user_id_here,another_user_id_here

# =============================
# Feature Flags
# =============================
PM_PERMIT=true
MAX_MESSAGE_LENGTH=4096

# =============================
# API Keys (Optional)
# =============================
OPENAI_API_KEY=your_openai_api_key_here
NEWS_API_KEY=your_news_api_key_here

# =============================
# Deployment
# =============================
HEROKU_APP_NAME=your_heroku_app_name_here
HEROKU_API_KEY=your_heroku_api_key_here

# =============================
# URLs
# =============================
GIT_REPO=https://github.com/corruptcrew/AllAtomic
SUPPORT_CHAT=@ComputeCode
UPDATE_CHANNEL=@ComputeCode
