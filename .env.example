# ═══════════════════════════════════════════════════════
# ⚛️  AllAtomic Userbot - Environment Configuration
# ═══════════════════════════════════════════════════════
# Dev: @GhostMarshal | Channel: @ComputeCode
# Theme: Purple Anime Aesthetic 🌸💜

# ───────────────────────────────────────────────────────
# 🔐 MANDATORY VARIABLES (Required for bot to work)
# ───────────────────────────────────────────────────────

# Get from https://my.telegram.org/apps
APP_ID=your_api_id_here
API_HASH=your_api_hash_here

# Telethon session string (generate via python3 -m telethon)
SESSION_STRING=your_session_string_here

# PostgreSQL Database URL (e.g., postgresql://user:pass@localhost:5432/allatomic)
DATABASE_URL=your_database_url_here

# Bot Token from @BotFather (optional, for some features)
BOT_TOKEN=your_bot_token_here

# Command handler (default: .)
HANDLER=.

# ───────────────────────────────────────────────────────
# 👤 USER CONFIGURATION
# ───────────────────────────────────────────────────────

# Your Telegram User ID (get from @userinfobot)
OWNER_ID=your_user_id_here

# Logger group/channel ID (for logging errors)
LOGGER_ID=your_logger_id_here

# Support group username (without @)
SUPPORT_GROUP=ComputeCode

# Update channel username (without @)
UPDATE_CHANNEL=ComputeCode

# ───────────────────────────────────────────────────────
# 🎨 CUSTOMIZATION (Optional)
# ───────────────────────────────────────────────────────

# Alive message custom text
ALIVE_MSG=⚛️ AllAtomic is Online!

# Alive image URL (gif/mp4/jpg)
ALIVE_PIC=https://i.imgur.com/your_image.gif

# PM Permit message
PMPERMIT_MSG=⚠️ Please wait for my master to approve you.

# Max spam messages before block
MAX_SPAM=5

# Custom sticker pack name
STICKER_PACKNAME=AllAtomic

# ───────────────────────────────────────────────────────
# 🔧 FEATURE TOGGLES
# ───────────────────────────────────────────────────────

# Enable/disable PM Permit (True/False)
PM_PERMIT=True

# Enable instant block in PM
INSTANT_BLOCK=False

# Enable abuse mode
ABUSE_MODE=False

# Enable AI features (requires API key)
AI_ENABLED=False

# ───────────────────────────────────────────────────────
# 🔑 API KEYS (Optional - for specific features)
# ───────────────────────────────────────────────────────

# OpenWeatherMap API (weather plugin)
WEATHER_API=your_weather_api_here

# Remove.bg API (background removal)
REMOVE_BG_API=your_removebg_api_here

# OpenAI API (AI chat features)
OPENAI_API=your_openai_api_here

# Exchange Rate API (currency converter)
CURRENCY_API=your_currency_api_here

# OCR API (text extraction)
OCR_API=your_ocr_api_here

# Genius API (lyrics)
LYRICS_API=your_genius_api_here

# ───────────────────────────────────────────────────────
# 🔄 UPDATE CONFIGURATION
# ───────────────────────────────────────────────────────

# GitHub repo for updates
UPSTREAM_REPO=https://github.com/yourusername/AllAtomic
UPSTREAM_BRANCH=main

# ═══════════════════════════════════════════════════════
# 💜 Made with love by @GhostMarshal
# ═══════════════════════════════════════════════════════
